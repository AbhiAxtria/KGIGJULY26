// run against the source DB; writes a fresh DB containing only the subset
MATCH (seed:Procedure) WHERE seed.name IN ['proc1','proc2','proc3']
CALL apoc.path.subgraphAll(seed, {relationshipFilter:'CALLS>|EXECUTES>|HAS_BLOCK>|CONTAINS>|DECLARES>|READS>|WRITES>|USES_VIEW>|USES_SEQUENCE>|REFERENCES>|REFERS_TO>|VIA_DBLINK>|DEPENDS_ON>|BELONGS_TO>|DB_OPERATION>|ASSESSED_AS>', maxLevel:-1})
YIELD nodes, relationships
CALL apoc.export.cypher.data(nodes, relationships, 'subset.cypher', {format:'plain'})
YIELD file RETURN file;
